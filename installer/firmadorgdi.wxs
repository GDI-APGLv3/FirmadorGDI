<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="FirmadorGDI"
    Manufacturer="Tecnología Acuario"
    Version="1.0.0"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
    Language="1033"
    InstallerVersion="500"
    Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="Ya tenés una versión más nueva de FirmadorGDI instalada." />

    <StandardDirectory Id="ProgramFilesFolder">
      <Directory Id="INSTALLFOLDER" Name="FirmadorGDI" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="FirmadorGDI" />
    </StandardDirectory>

    <ComponentGroup Id="MainComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExe" Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
        <File Id="FirmadorGDIExe"
              Source="..\firmadorgdi.exe"
              KeyPath="yes" />

        <!-- Registrar gdifirma:// URI scheme -->
        <RegistryKey Root="HKCU" Key="Software\Classes\gdifirma">
          <RegistryValue Type="string" Value="URL:GDI Firma Protocol" />
          <RegistryValue Name="URL Protocol" Type="string" Value="" />
        </RegistryKey>
        <RegistryKey Root="HKCU" Key="Software\Classes\gdifirma\shell\open\command">
          <RegistryValue Type="string" Value='"[INSTALLFOLDER]firmadorgdi.exe" "%1"' />
        </RegistryKey>
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ShortcutComponents" Directory="AppMenuFolder">
      <Component Id="StartMenuShortcut" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
        <Shortcut Id="AppShortcut"
                  Name="FirmadorGDI"
                  Description="Firma PDFs con tu token físico desde Chrome"
                  Target="[INSTALLFOLDER]firmadorgdi.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="AppMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\GDILatam\FirmadorGDI"
                       Name="installed"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="MainFeature" Title="FirmadorGDI" Level="1">
      <ComponentGroupRef Id="MainComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>

    <WixVariable Id="WixUILicenseRtf" Value="license.rtf" />
    <WixVariable Id="WixUIDialogBmp" Value="dialog.bmp" />
    <WixVariable Id="WixUIBannerBmp" Value="banner.bmp" />
    <ui:WixUI Id="WixUI_Minimal" />

  </Package>
</Wix>
